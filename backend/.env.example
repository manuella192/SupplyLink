# ── Serveur ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Base de données MySQL ─────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=supplylink

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=changeme_use_at_least_64_random_chars_in_production
JWT_EXPIRES_IN=7d

# ── Frontend URL (CORS whitelist) ─────────────────────────
CLIENT_URL=http://localhost:3000

# ── Nodemailer (Gmail SMTP) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=votre.adresse@gmail.com
SMTP_PASS=votre_app_password_gmail
EMAIL_FROM="SupplyLink <no-reply@supplylink.ma>"

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Upload ────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=2
